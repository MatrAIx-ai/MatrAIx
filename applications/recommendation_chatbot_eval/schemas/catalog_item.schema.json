{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MatrAIx-ai/MatrAIx/applications/recommendation_chatbot_eval/schemas/catalog_item.schema.json",
  "title": "RecommendationCatalogItem",
  "type": "object",
  "required": ["item_id", "domain", "title", "display_text", "source"],
  "properties": {
    "item_id": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "display_text": {
      "type": "string",
      "minLength": 1
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "signals": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "integer", "string", "boolean", "null"]
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": true
    },
    "domain_metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "source": {
      "type": "object",
      "required": ["dataset"],
      "properties": {
        "dataset": {
          "type": "string",
          "minLength": 1
        },
        "license": {
          "type": "string"
        },
        "original_id": {
          "type": ["string", "number", "integer", "null"]
        },
        "url": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
