#!/bin/bash
#SBATCH -p seas_gpu,gpu_h200
#SBATCH --gres=gpu:nvidia_h200:1
#SBATCH -n 1
#SBATCH -c 16
#SBATCH --mem=128G
#SBATCH -t 1-00:00
#SBATCH -o sbatch_logs/%x_%A_%a.out
#SBATCH -e sbatch_logs/%x_%A_%a.err
#SBATCH --mail-type=FAIL
#SBATCH --mail-user=xiaominli@g.harvard.edu

set -uo pipefail

mamba init >/dev/null 2>&1 || true
module load python/3.10.13-fasrc01
module load gcc/12.2.0-fasrc01
module load cuda/12.4.1-fasrc01
conda activate env05

REPO_ROOT="/n/netscratch/lu_lab/Lab/xiaominli/LLMResearch/MatrAIx-amazon-resume"
PY="/n/home08/xiaominli/.conda/envs/env05/bin/python"
GROUPS_FILE="${GROUPS_FILE:-$REPO_ROOT/persona/human_extraction/jobs/amazon_bucket_groups_20260718.txt}"
OUT_DIR="${OUT_DIR:-/n/netscratch/lu_lab/Lab/xiaominli/LLMResearch/MatrAIx/persona/human_extraction/data/amazon/extraction_resume_20260717}"

export HF_HOME="/n/netscratch/lu_lab/Lab/xiaominli/mycache/hf_home"
export HF_HUB_CACHE="$HF_HOME/hub"
export HF_XET_CACHE="$HF_HOME/xet"
TASK_CACHE_TAG="${SLURM_ARRAY_JOB_ID:-manual}_${SLURM_ARRAY_TASK_ID:-0}_${SLURM_JOB_ID:-$$}"
LOCAL_CACHE_ROOT="${SLURM_TMPDIR:-/tmp}/${USER}/matraix-amazon-group-${TASK_CACHE_TAG}"
export VLLM_CACHE_ROOT="$LOCAL_CACHE_ROOT/vllm"
export FLASHINFER_WORKSPACE_BASE="$LOCAL_CACHE_ROOT/flashinfer"
export TORCH_EXTENSIONS_DIR="$LOCAL_CACHE_ROOT/torch-extensions"
export TORCHINDUCTOR_CACHE_DIR="$LOCAL_CACHE_ROOT/torchinductor"
export TRITON_CACHE_DIR="$LOCAL_CACHE_ROOT/triton"
export VLLM_WORKER_MULTIPROC_METHOD=spawn
export REPO_ROOT
export SELECTION_PATH="/n/netscratch/lu_lab/Lab/xiaominli/LLMResearch/MatrAIx/persona/human_extraction/data/amazon/selected_users_100k_koutian.parquet"

mkdir -p "$VLLM_CACHE_ROOT" "$FLASHINFER_WORKSPACE_BASE" "$TORCH_EXTENSIONS_DIR" \
    "$TORCHINDUCTOR_CACHE_DIR" "$TRITON_CACHE_DIR" sbatch_logs "$OUT_DIR"

GROUP_INDEX="${SLURM_ARRAY_TASK_ID:?SLURM_ARRAY_TASK_ID is required}"
BUCKET_IDS=$(sed -n "$((GROUP_INDEX + 1))p" "$GROUPS_FILE")
if [[ -z "$BUCKET_IDS" ]]; then
    echo "No bucket group found for index=$GROUP_INDEX in $GROUPS_FILE" >&2
    exit 2
fi

echo "=== Amazon grouped medium_b resume on H200 ==="
echo "date=$(date -Is) host=$(hostname) group_index=$GROUP_INDEX buckets=$BUCKET_IDS"
echo "out_dir=$OUT_DIR local_cache_root=$LOCAL_CACHE_ROOT slurm_job=${SLURM_JOB_ID:-none}"
nvidia-smi --query-gpu=name,memory.total,driver_version --format=csv,noheader | head -1
echo "compiler=$(gcc --version | head -1)"

cd "$REPO_ROOT"
group_start=$(date +%s)
for SHARD_ID in $BUCKET_IDS; do
    start=$(date +%s)
    echo "BUCKET_START shard_id=$SHARD_ID bucket=$(printf '%02x' "$SHARD_ID") date=$(date -Is)"
    "$PY" -u persona/human_extraction/scripts/run_extraction_amazon.py \
        --shard-id "$SHARD_ID" \
        --out-dir "$OUT_DIR" \
        --batch-profiles 16 \
        --tensor-parallel 1 \
        --quantization fp8 \
        --prompt-variant medium_b \
        --gpu-mem 0.90 \
        --max-num-seqs 64 \
        --limit 0
    rc=$?
    echo "BUCKET_DONE shard_id=$SHARD_ID rc=$rc elapsed=$(( $(date +%s) - start ))s"
    if [[ $rc -ne 0 ]]; then
        exit "$rc"
    fi
done
echo "GROUP_DONE index=$GROUP_INDEX buckets=$BUCKET_IDS elapsed=$(( $(date +%s) - group_start ))s"