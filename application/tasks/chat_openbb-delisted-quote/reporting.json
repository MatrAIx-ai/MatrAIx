{
  "schemaVersion": "1.0",
  "contextRules": [
    {
      "match": {
        "contextType": "product_behavior"
      },
      "distributions": [
        {
          "id": "product_behavior.failure_mode_by_segment",
          "facetKey": "failure_mode",
          "title": "Text failure mode"
        },
        {
          "id": "product_behavior.failure_mode_by_trust",
          "facetKey": "failure_mode",
          "title": "Failure mode by trust level",
          "groupByPersonaDimensions": [
            "trust_level"
          ]
        },
        {
          "id": "product_behavior.failure_mode_by_skepticism",
          "facetKey": "failure_mode",
          "title": "Failure mode by skepticism",
          "groupByPersonaDimensions": [
            "cog_skepticism"
          ]
        }
      ],
      "summaryAnalyses": [
        {
          "id": "product_behavior.failure_themes",
          "title": "Failure themes by corporate-action type",
          "targetFacetKey": "failure_mode",
          "groupByFacetKey": "price_class",
          "summaryKind": "llm_bucket_summary",
          "instruction": "For each price_class bucket, summarize in 1-2 sentences what the product typically did wrong or right on corporate actions. Stay faithful to the failure_mode labels; do not invent tickers or prices."
        }
      ]
    },
    {
      "match": {
        "contextType": "trust_calibration"
      },
      "distributions": [
        {
          "id": "trust.continue_use_by_segment",
          "facetKey": "would_still_continue_use",
          "title": "Would still continue use"
        },
        {
          "id": "trust.calibration_by_segment",
          "facetKey": "calibration",
          "title": "Continue-use vs failure mode"
        },
        {
          "id": "trust.calibration_by_confidence",
          "facetKey": "calibration",
          "title": "Calibration by confidence calibration",
          "groupByPersonaDimensions": [
            "cog_confidence_calibration"
          ]
        },
        {
          "id": "trust.rating_by_segment",
          "facetKey": "overall_experience_rating",
          "title": "Satisfaction score (1-10)"
        }
      ]
    },
    {
      "match": {
        "contextType": "user_feedback"
      },
      "distributions": [
        {
          "id": "feedback.rating_by_segment",
          "facetKey": "overall_experience_rating",
          "title": "Satisfaction score (1-10)"
        },
        {
          "id": "feedback.continue_use_by_segment",
          "facetKey": "would_still_continue_use",
          "title": "Would still continue use (self-report)"
        },
        {
          "id": "feedback.need_by_segment",
          "facetKey": "need_constraint_satisfaction",
          "title": "Need / constraint satisfaction"
        },
        {
          "id": "feedback.corp_action_handling_by_segment",
          "facetKey": "assistant_handled_corporate_action_well",
          "title": "Handled corporate action well"
        },
        {
          "id": "feedback.rating_by_trust",
          "facetKey": "overall_experience_rating",
          "title": "Satisfaction by trust level",
          "groupByPersonaDimensions": [
            "trust_level"
          ]
        }
      ]
    },
    {
      "match": {
        "contextType": "task_outcome"
      },
      "distributions": [
        {
          "id": "outcome.coverage",
          "facetKey": "scenario_coverage",
          "title": "Ticker coverage (N of 4)"
        },
        {
          "id": "outcome.freshness_probe",
          "facetKey": "freshness_probe_made",
          "title": "Freshness / follow-up probe made"
        }
      ]
    }
  ]
}
