      "judgeDirectives": [
        {
          "id": "decision.holdem_signal_scan",
          "title": "Texas Hold'em decision signal scan",
          "targetFacetKey": "reason",
          "groupByFacetKey": "risk_posture",
          "groupByMode": "categorical",
          "judgeKind": "llm_signal_judge",
          "prompt": "Read the persona's Texas Hold'em decision reason and classify which strategic signals are explicitly present.",
          "rubric": "Mark a signal true only when the reason clearly states or strongly implies that signal.",
          "signals": [
            {
              "key": "hand_strength_signal",
              "label": "Hand strength reasoning",
              "valueType": "boolean"
            },
            {
              "key": "pot_odds_signal",
              "label": "Pot odds or value calculation",
              "valueType": "boolean"
            },
            {
              "key": "bluff_signal",
              "label": "Bluffing or bluff-catching",
              "valueType": "boolean"
            },
            {
              "key": "risk_control_signal",
              "label": "Risk control or chip preservation",
              "valueType": "boolean"
            }
          ]
        },
        {
          "id": "decision.persona_alignment_judge",
          "title": "Persona-behavior alignment judge",
          "targetFacetKey": "reason",
          "groupByFacetKey": "risk_posture",
          "groupByMode": "categorical",
          "judgeKind": "llm_signal_judge",
          "prompt": "Evaluate whether the persona played consistent with their specified risk posture and decision style.",
          "rubric": "Mark true if the gameplay actions and reasoning reflect their stated persona dimensions.",
          "signals": [
            {
              "key": "persona_consistency_signal",
              "label": "Persona behavioral consistency",
              "valueType": "boolean"
            }
          ]
