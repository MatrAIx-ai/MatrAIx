{
  "schemaVersion": "1.0",
  "contextRules": [
    {
      "match": { "contextType": "task_outcome" },
      "summaryDirectives": [
        {
          "id": "task_outcome.explanation_by_trait",
          "title": "Game outcome explanation by dominant trait",
          "targetFacetKey": "outcome_explanation",
          "groupByFacetKey": "task_dominant_trait",
          "groupByMode": "categorical",
          "summaryKind": "llm_bucket_summary"
        }
      ]
    },
    {
      "match": { "contextType": "task_reasoning_trajectory" },
      "summaryDirectives": [
        {
          "id": "reasoning.trajectory_by_trait",
          "title": "Reasoning trajectory by dominant trait",
          "targetFacetKey": "task_reasoning_text",
          "groupByFacetKey": "task_dominant_trait",
          "groupByMode": "categorical",
          "summaryKind": "llm_bucket_summary"
        }
      ],
      "judgeDirectives": [
        {
          "id": "reasoning.play_style_scan",
          "title": "Play-style signal scan by trait",
          "targetFacetKey": "task_reasoning_text",
          "groupByFacetKey": "task_dominant_trait",
          "groupByMode": "categorical",
          "judgeKind": "llm_signal_judge",
          "prompt": "Read the persona's reasoning trajectory across the run and classify which play-style signals are present. This is a starting rubric; some signals are game-specific (duels, proximity-seeking, bluffing) and may be extended per game.",
          "rubric": "Mark a signal true only when the reasoning text clearly states or strongly implies it.",
          "signals": [
            { "key": "confusion_signal", "label": "Seemed lost or contradictory about the game state", "valueType": "boolean" },
            { "key": "engagement_signal", "label": "Seemed invested in moment-to-moment play", "valueType": "boolean" },
            { "key": "funness_signal", "label": "Read as playful or fun rather than mechanical", "valueType": "boolean" }
          ]
        }
      ]
    }
  ]
}
