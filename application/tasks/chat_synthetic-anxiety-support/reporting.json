        },
        {
          "id": "user_feedback.coping_by_segment",
          "facetKey": "task_coping_strategy_helpfulness",
          "title": "Coping strategy helpfulness"
        }
      ]
    },
    {
      "match": {
        "contextType": "policy_and_trust"
      },
      "distributions": [
        {
          "id": "policy_and_trust.compliance_by_segment",
          "facetKey": "policy_compliance",
          "title": "Policy compliance"
        }
      ]
    }
  ]
}
